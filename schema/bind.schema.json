{
  "title": "JTOX Binding",
  "description": "A $bind object that resolves to a value at render time",
  "type": "object",
  "required": ["$bind"],
  "properties": {
    "$bind": {
      "type": "string",
      "pattern": "^(settings|props|scope|theme|context|state|self)\\.",
      "description": "Dot-notation path with scope prefix"
    },
    "type": {
      "type": "string",
      "enum": ["string", "number", "boolean", "array", "object"],
      "description": "Expected value type"
    },
    "default": {
      "description": "Fallback value if path resolves to null"
    },
    "transform": {
      "description": "Transform(s) to apply to the resolved value. String shorthand for zero-arg transforms, object for parameterized, array for chaining.",
      "oneOf": [
        {
          "type": "string",
          "description": "Shorthand for a zero-argument transform"
        },
        {
          "$ref": "#/$defs/transformObject",
          "description": "Single parameterized transform"
        },
        {
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "string" },
              { "$ref": "#/$defs/transformObject" }
            ]
          },
          "description": "Chain of transforms applied left to right"
        }
      ]
    }
  },
  "additionalProperties": false,
  "$defs": {
    "transformObject": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "description": "The transform identifier"
        },
        "args": {
          "type": "object",
          "description": "Named arguments (keys depend on the transform)",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    }
  }
}
